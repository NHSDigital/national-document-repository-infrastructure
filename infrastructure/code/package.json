{
    "name": "cloudfront-functions",
    "version": "0.1.0",
    "private": true,
    "description": "CloudFront Functions 2.0 source + tests. Compiled output in dist/ is deployed by Terraform.",
    "scripts": {
        "build": "tsc -p tsconfig.build.json && sed -i 's/export //g' dist/block-invalid-urls.js",
        "test": "vitest run --coverage",
        "test:watch": "vitest"
    },
    "devDependencies": {
        "@types/aws-cloudfront-function": "^1.0.8",
        "@types/node": "^24.12.2",
        "@vitest/coverage-v8": "^4.1.4",
        "typescript": "~5.9.3",
        "vitest": "^4.1.4"
    }
}
